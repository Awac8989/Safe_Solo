# Database
DATABASE_URL="postgresql://username:password@localhost:5432/safesolo_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here-change-this-in-production"
JWT_EXPIRE="7d"

# Server
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# Email Service (for OTP - integrate with your email provider)
# EMAIL_SERVICE="gmail"
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS="your-app-password"

# Redis (optional - for rate limiting and caching)
# REDIS_URL="redis://localhost:6379"

# Legacy SMS settings (if still needed)
WORKER_INTERVAL_MS=60000
ESCALATION_REMINDER_MINUTES=30
ESCALATION_WARNING_MINUTES=5
ESCALATION_SOS_MINUTES=15

SMS_PRIMARY_PROVIDER=mock
SMS_PRIMARY_WEBHOOK_URL=
SMS_PRIMARY_WEBHOOK_TOKEN=

SMS_FALLBACK_PROVIDER=none
SMS_FALLBACK_WEBHOOK_URL=
SMS_FALLBACK_WEBHOOK_TOKEN=

SMS_MAX_RETRIES=2
SMS_RETRY_DELAY_MS=1200
SMS_REQUEST_TIMEOUT_MS=7000