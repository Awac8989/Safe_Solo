// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model - Core entity for authentication and profile management
model User {
  id                String   @id @default(cuid())
  email             String   @unique
  phone             String?  @unique
  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  gender            Gender?
  avatar            String?
  isActive          Boolean  @default(true)
  isVerified        Boolean  @default(false)
  otpCode           String?
  otpExpiresAt      DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  trust_score       Float    @default(5.0)
  rescues_count     Int      @default(0)
  is_kyc_verified   Boolean  @default(false)
  next_checkin_deadline DateTime?
  is_auto_wipe_enabled Boolean @default(false)
  auto_wipe_days    Int?
  deadmanStage      Int      @default(0)
  deadmanEscalationTriggeredAt DateTime?

  // Location fields for Community Radar
  lastLat           Float?
  lastLng           Float?
  lastLocationTime  DateTime?
  location          Unsupported("geometry(Point,4326)")?

  // Relations
  medicalProfile    MedicalProfile?
  sentRequests      GuardianRelationship[] @relation("GuardianRequests")
  receivedRequests  GuardianRelationship[] @relation("GuardianResponses")
  victimIncidents   RescueIncident[]       @relation("VictimIncidents")
  vault             Vault?
  volunteerResponses VolunteerResponse[]
  messages          Message[]
  receivedThankYouNotes ThankYouNote[]    @relation("VolunteerThankYouNotes")
  sentThankYouNotes     ThankYouNote[]    @relation("AuthorThankYouNotes")
  dailyStatuses     DailyStatus[]
  kycDocument       KYCDocument?

  @@map("users")
}

// Medical Profile - Health information for emergency contacts
model MedicalProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  bloodType         BloodType?
  allergies         String[] // Array of allergy descriptions
  medications       String[] // Array of medication names
  medicalConditions String[] // Array of medical conditions
  emergencyContact  Json?    // {name: string, phone: string, relationship: string}
  insuranceInfo     Json?    // {provider: string, policyNumber: string, groupNumber: string}
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_profiles")
}

// Guardian Relationship - Network of emergency contacts
model GuardianRelationship {
  id          String   @id @default(cuid())
  requesterId String
  guardianId  String
  status      RelationshipStatus @default(PENDING)
  escalationLevel Int    @default(1)
  guardianConfirmedAt DateTime?
  lastNotifiedAt DateTime?
  message     String?  // Optional message from requester
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  requester   User     @relation("GuardianRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  guardian    User     @relation("GuardianResponses", fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([requesterId, guardianId])
  @@map("guardian_relationships")
}

// Rescue Incident - Emergency incidents for Community Radar
model RescueIncident {
  id           String   @id @default(cuid())
  victimId     String
  status       IncidentStatus @default(ACTIVE)
  incidentType String   // e.g., "medical_emergency", "accident", etc.
  severity     Int      @default(1)
  exactLat     Float    // Precise coordinates
  exactLng     Float
  fuzzedLat    Float    // Fuzzed coordinates for privacy (50m offset)
  fuzzedLng    Float
  createdAt    DateTime @default(now())
  resolvedAt   DateTime?

  // Relations
  victim       User              @relation("VictimIncidents", fields: [victimId], references: [id], onDelete: Cascade)
  responses    VolunteerResponse[]
  chatRoom     ChatRoom?
  systemLogs   SystemLog[]

  @@map("rescue_incidents")
}

// Volunteer Response - Mapping of volunteers to rescue incidents
model VolunteerResponse {
  id         String   @id @default(cuid())
  incidentId String
  volunteerId String
  status     ResponseStatus @default(EN_ROUTE)
  createdAt  DateTime @default(now())

  // Relations
  incident   RescueIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  volunteer  User           @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([incidentId, volunteerId])
  @@map("volunteer_responses")
}

// Enums
enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum RelationshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum IncidentStatus {
  ACTIVE
  RESOLVED
  CANCELLED
}

enum ResponseStatus {
  EN_ROUTE
  ARRIVED
  CANCELLED
}

// Chat Room - Emergency chat rooms for rescue incidents
model ChatRoom {
  id         String   @id @default(cuid())
  incidentId String   @unique
  status     ChatRoomStatus @default(ACTIVE)
  createdAt  DateTime @default(now())
  closedAt   DateTime?

  // Relations
  incident   RescueIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@map("chat_rooms")
}

// Message - Chat messages in emergency rooms
model Message {
  id           String   @id @default(cuid())
  roomId       String
  senderId     String?
  messageType  MessageType
  content      String   // Text content or file URL for audio
  createdAt    DateTime @default(now())

  // Relations
  room         ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender       User?    @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@map("messages")
}

// Daily Status - Alive Circle updates by users
model DailyStatus {
  id          String   @id @default(cuid())
  userId      String
  mood_emoji  String
  audio_url   String?
  createdAt   DateTime @default(now())

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("daily_statuses")
}

// Thank You Note - appreciation notes for volunteers
model ThankYouNote {
  id          String   @id @default(cuid())
  volunteerId String
  authorId    String
  content     String
  createdAt   DateTime @default(now())

  // Relations
  volunteer   User     @relation("VolunteerThankYouNotes", fields: [volunteerId], references: [id], onDelete: Cascade)
  author      User     @relation("AuthorThankYouNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@map("thank_you_notes")
}

// KYC Document - Identity verification uploads
model KYCDocument {
  id             String   @id @default(cuid())
  userId         String   @unique
  front_image_url String
  back_image_url  String
  status         KYCStatus @default(PENDING)
  submitted_at   DateTime @default(now())

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

// Vault - Sensitive user information for auto-wipe protection
model Vault {
  id         String   @id @default(cuid())
  userId     String   @unique
  content    Json?
  shreddedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vaults")
}

// SystemLog - Audit and automation traceability
model SystemLog {
  id          String   @id @default(cuid())
  incidentId  String?
  action_type String
  description String
  createdAt   DateTime @default(now())

  incident    RescueIncident? @relation(fields: [incidentId], references: [id])

  @@map("system_logs")
}

// Enums for Chat
enum ChatRoomStatus {
  ACTIVE
  READ_ONLY
}

enum MessageType {
  TEXT
  AUDIO
  SYSTEM
  LOCATION
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}
